	~		|

Surface Albedo = A FUNCTION OF( Glacier Ice,BC Albedo Effect)
	~	Dmnl
	~		|

Glacier Melt Rate = A FUNCTION OF( Temperature,Black Carbon,Thermal Undercutting)
	~	Dmnl
	~		|

Snowfall = A FUNCTION OF( Temperature)
	~	Dmnl
	~		|

GLOF Risk = A FUNCTION OF( Glacial Lake)
	~	Dmnl
	~		|

Thermal Undercutting = A FUNCTION OF( Glacial Lake,Temperature)
	~	Dmnl
	~		|

Human Emission = A FUNCTION OF( )
	~	Dmnl
