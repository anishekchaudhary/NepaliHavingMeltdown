Permafrost Emission = A FUNCTION OF( Temperature)
	~	Dmnl
	~		|

Ocean Sink = A FUNCTION OF( GreenHouseGas)
	~	Dmnl
	~		|

Terrestrial Sink = A FUNCTION OF( Forest Cover)
	~	Dmnl
	~		|

