{UTF-8}
Removal=Ocean Sink + Terrestrial Sink
	~	Gt CO2/Year
	~		|

Base Deforestation Rate=0.012
	~	1/Year
	~		|

Drainage Fraction=0.08
	~	1/Year
	~		|

Base Afforestation Rate=0.014
	~	1/Year
	~		|

GLOF Risk Index=MIN(1, Glacial Lake / GLOF Threshold)
	~	dmnl
	~		|

Glaciers Volume= INTEG (Glacial Deposit-Glacier Melt Rate,
		312)
	~	km*km*km
	~		|

Snow Cover= INTEG (Snowfall Precipitation-Glacial Deposit,
		50)
	~	km*km*km
	~		|

Glacial Deposit=MAX(0, Accumulation Rate * Annual Snowfall - Surface Melt Rate * Delta Temperature\
		)
	~	km*km*km/Year
	~		|

Flood Pressure=0.002 * GLOF Risk Index
	~	1/Year
	~		|

Green House Gas= INTEG (
	Emission - Removal,
		830)
	~	Gt CO2
	~		|

Emission=
	Human Emission + Permafrost Emission
	~	Gt CO2/Year
	~		|

Human Emission=IF THEN ELSE ( Time < 2030 , 36 * EXP(0.018 * (Time - 1980)) , 36 * EXP\
		(0.01 * (Time - 1980)) )
	~	Gt CO2/Year
	~		|

Permafrost Emission=IF THEN ELSE(Delta Temperature > Permafrost Thaw Threshold,
		0.0154 * (Delta Temperature - Permafrost Thaw Threshold), 0)
	~	Gt CO2/Year
	~		|

Ocean Sink=10.6 * LN(Green House Gas / Initial GHG + 1)
	~	Gt CO2/Year
	~		|

Terrestrial Sink=
	3.1 + 4.84e-05 * Forest Cover
	~	Gt CO2/Year
	~		|

Permafrost Thaw Threshold=
	1.5
	~	dmnl
	~		|

Temperature=
	Base Temperature at glacial altitute + Delta Temperature
	~	Celsius
	~		|

Delta Temperature=
	GHG Temperature Effect + Albedo Temperature Effect
	~	dmnl
	~		|

Base Temperature at glacial altitute=-15
	~	Celsius
	~		|

GHG Temperature Effect=
	3 * LN(MAX(Green House Gas / Initial GHG, 1))
	~	dmnl
	~		|

Albedo Temperature Effect=
	1.5 * (0.62 - Surface Albedo)
	~	dmnl
	~		|

Surface Albedo=
	MAX(0.15, 0.25 + 0.37 * Ice Fraction - BC Albedo Effect)
	~	dmnl
	~		|

BC Albedo Effect=
	0.038 * MIN(1, Black Carbon / Initial Black Carbon)
	~	dmnl
	~		|

Ice Fraction=
	MIN(1, MAX(0, Total Ice / Initial Ice))
	~	dmnl
	~		|

Total Ice=
	Glaciers Volume + Snow Cover
	~	km*km*km
	~		|

Initial Ice=
	362
	~	km*km*km
	~		|

Initial GHG=
	830
	~	Gt CO2
	~		|

Accumulation Rate=
	0.55
	~	dmnl
	~		|

Annual Snowfall=
	Snow Probability * Base Precipitation * Glacier Area
	~	km*km*km/Year
	~		|

Surface Melt Rate=0.25
	~	km*km*km/(Year*Celsius)
	~		|

Glacier Melt Rate=
	MAX(0, (Melt Sensitivity + BC Melt Enhancement) * Delta Temperature * Glacier Area)
	~	km*km*km/Year
	~		|

Melt Sensitivity=
	0.86
	~	km/Year
	~		|

BC Melt Enhancement=
	0.39 * Melt Sensitivity * MIN(1, Black Carbon / Initial Black Carbon)
	~	km/Year
	~		|

Glacier Area=
	0.363
	~	km*km
	~		|

Snowfall Precipitation=
	Snow Probability * Base Precipitation * Snow Area
	~	km*km*km/Year
	~		|

Snow Probability=1 / (1 + EXP ( 1.2 * (Temperature - 3) ) )
	~	dmnl
	~		|

Base Precipitation=
	1.5
	~	km/Year
	~		|

Snow Area=
	0.8
	~	km*km
	~		|

Humidity=
	0.75
	~	dmnl
	~		|

Altitude=
	4500
	~	m
	~		|

Glacial Lake= INTEG (Meltwater Inflow - Lake Drainage,
		0.5)
	~	km*km*km
	~		|

Meltwater Inflow=MIN(Glacier Melt Rate, Lake Feed Fraction * Glacier Melt Rate + Thermal Undercutting\
		)
	~	km*km*km/Year
	~		|

Lake Feed Fraction=
	0.3
	~	dmnl
	~		|

Lake Drainage=
	Drainage Fraction * Glacial Lake
	~	km*km*km/Year
	~		|

Thermal Undercutting=
	Undercutting Coefficient * Glacial Lake * MAX(0, Delta Temperature)
	~	km*km*km/Year
	~		|

Undercutting Coefficient=0.025
	~	1/Year
	~		|

GLOF Threshold=50
	~	km*km*km
	~		|

Forest Cover= INTEG (
	Afforestation - Deforestation,
		64000)
	~	km*km
	~		|

Afforestation=
	Base Afforestation Rate * Forest Cover
	~	km*km/Year
	~		|

Deforestation=
	(Base Deforestation Rate + Flood Pressure) * Forest Cover
	~	km*km/Year
	~		|

Black Carbon= INTEG (
	BC Emission - BC Decay,
		120)
	~	Gg
	~		|

BC Emission=60 * EXP(0.012 * (Time - 1980))
	~	Gg/Year
	~		|

BC Decay=
	BC Lifetime Fraction * Black Carbon
	~	Gg/Year
	~		|

BC Lifetime Fraction=
	0.5
	~	1/Year
	~		|

Initial Black Carbon=
	120
	~	Gg
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 2080
	~	Year
	~	The final time for the simulation.
	|

INITIAL TIME  = 1980
	~	Year
	~	The initial time for the simulation.
	|

SAVEPER  =
        TIME STEP
	~	Year [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.125
	~	Year [0,?]
	~	The time step for the simulation.
	|

