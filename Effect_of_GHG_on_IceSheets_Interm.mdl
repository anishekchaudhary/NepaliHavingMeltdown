{UTF-8}
GHG Temperature Effect  = A FUNCTION OF( Initial GHG) ~~|
GHG Temperature Effect=1.5 * LN(MAX(GreenHouseGas / Initial GHG, 1))
	~	dmnl
	~		|

Albedo Temperature Effect=15 * (0.7 - Surface Albedo)
	~	dmnl
	~		|

Snow Probability=1 / (1+EXP(0.8*(Temperature -2)))
	~	dmnl
	~		|

Surface Albedo=0.2 + (0.5 * Ice Fraction)
	~	dmnl
	~		|

Ice Fraction=MIN ( 1 , Total Ice/Initial Ice )
	~	dmnl
	~		|

Initial Ice=1272.57
	~	km*km*km
	~		|

Total Ice=Glaciers Volume + Snow cover
	~	km*km*km
	~		|

Temperature=5+ GHG Temperature Effect + Albedo Temperature Effect
	~	dmnl
	~		|

Initial GHG=3
	~	mln metric ton
	~		|

Excess flow rate=
	0.1*Melting to main water bodies*(Temperature-5)/100/Duration
	~	km*km*km/Month
	~		|

Natural flow=
	(Melting to main water bodies-Excess flow rate)/Duration
	~	km*km*km/Month
	~		|

Km Unit=1
	~	km
	~		|

Afforestation=
	0.005*Forest cover/Duration
	~	km*km/Month
	~		|

Kg Unit=1
	~	kg
	~		|

MMT=1
	~	mln metric ton
	~		|

Deforrestation=
	(0.012+1e-05*Flood Water/(Km Unit*Km Unit*Km Unit))*Forest cover/Duration
	~	(km*km)/Month
	~		|

Duration=
	1
	~	Month
	~		|

Residual flow=
	0.6*Flood Water/Duration
	~	km*km*km/Month
	~		|

Evaporation=
	1e-05*Temperature*(Glacial Lake)/Duration
	~	km*km*km/Month
	~		|

Glacial Deposit=
	0.7*Snowfall Precipitation-0.3*Temperature*Km Unit*Km Unit*Km Unit/Duration
	~	km*km*km/Month
	~		|

Oceanic Evaporation=
	0.5*(1-Humidity)*Temperature*Km Unit*Km Unit*Km Unit/Duration
	~	km*km*km/Month
	~		|

Melting to glacial=
	0.2*Temperature*Km Unit*Km Unit*Km Unit/Duration+0.5*Precipitation*Km Unit*Km Unit*Km Unit\
		/Kg Unit
	~	km*km*km/Month
	~		|

Cloud Formation=(0.5*(Evaporation+Oceanic Evaporation)/(Km Unit*Km Unit*Km Unit)+((0.3\
		*Humidity-0.1*Temperature)+0.3*Transpirated water/(Km Unit*Km Unit*Km Unit))/Duration
	)*Kg Unit
	~	kg/Month
	~		|

Snowfall Precipitation=
	0.9*Precipitation*Snow Probability*Km Unit*Km Unit*Km Unit/Kg Unit+0.005*Altitude*Km Unit\
		*Km Unit/Duration
	~	km*km*km/Month
	~		|

Transpiration rate=
	0.1*(Temperature/25)*(1-Humidity)*Km Unit
	~	km
	~		|

Melting to main water bodies=
	0.1*(Temperature/15)*Km Unit*Km Unit*Km Unit/Duration+0.02*Precipitation*Km Unit*Km Unit\
		*Km Unit/Kg Unit
	~	km*km*km/Month
	~		|

Precipitation=
	0.3*Humidity*EXP(-0.1*Temperature)*Kg Unit/Duration
	~	kg/Month
	~		|

Transpirated water=
	Transpiration rate*Forest cover
	~	km*km*km
	~		|

Altitude=
	3300
	~	km
	~		|

Clouds in Atmosphere= INTEG (
	Cloud Formation-Precipitation,
		8.2e+11)
	~	kg
	~		|

Humidity=
	0.75
	~	dmnl
	~		|

Main Stream= INTEG (
	Melting to main water bodies-Excess flow rate-Natural flow,
		680)
	~	km*km*km
	~		|

Flood Water= INTEG (
	Excess flow rate-Residual flow,
		0)
	~	km*km*km
	~		|

Forest cover= INTEG (
	Afforestation-Deforrestation,
		1e+06)
	~	km*km
	~		|

Glacial Lake= INTEG (
	Melting to glacial-Evaporation,
		61)
	~	km*km*km
	~		|

Glaciers Volume= INTEG (
	Glacial Deposit-Melting to glacial-Melting to main water bodies,
		1110)
	~	km*km*km
	~		|

"Water deposited to Oceans/Sea"= INTEG (
	Natural flow+Residual flow-Oceanic Evaporation,
		1953 )
	~	km*km*km
	~		|

Snow cover= INTEG (
	Snowfall Precipitation-Glacial Deposit,
		162.57)
	~	km*km*km
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 100
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 1
	~	Month [0,?]
	~	The time step for the simulation.
	|

